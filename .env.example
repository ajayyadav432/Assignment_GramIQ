# ─── AI Provider Configuration ──────────────────────
# Options: "mock" (no API key needed), "gemini", "groq", or "openai"
AI_PROVIDER=mock

# Required only when AI_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# Required only when AI_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Required only when AI_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# ─── Database ───────────────────────────────────────
# These match the docker-compose.yml defaults
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=krishiclinic
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/krishiclinic

# ─── Frontend ───────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
